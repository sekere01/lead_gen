# Lead Generation Discovery Service - Environment Configuration
# Copy this file to .env and fill in your actual values
# REQUIRED: DATABASE_URL must be set - no default provided

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/leadgen_db

# =============================================================================
# DATABASE CONNECTION POOL
# =============================================================================
# Increase pool_size if seeing "QueuePool limit reached" errors
# Discovery uses up to 3 concurrent workers (LLM calls), so:
#   - pool_size: 4 (main loop + 3 workers)
#   - max_overflow: 3 (burst to 7 total)
#   - pool_timeout: 10 (seconds)
DB_POOL_SIZE=4
DB_MAX_OVERFLOW=3
DB_POOL_TIMEOUT=10

# =============================================================================
# DISCOVERY SETTINGS
# =============================================================================
# Poll interval in seconds (how often to check for new jobs)
DISCOVERY_POLL_INTERVAL=300

# Maximum number of job retry attempts before marking as failed
MAX_JOB_RETRIES=3

# Search result cache duration in hours
SEARCH_CACHE_HOURS=24

# Delay between DuckDuckGo requests (seconds) — polite crawling
SEARCH_DDGS_DELAY=2

# Delay between SearXNG requests (seconds) — polite crawling
SEARCH_SEARXNG_DELAY=1

# Base URL for the API (used for metrics reporting)
API_BASE=http://localhost:8000/api/v1