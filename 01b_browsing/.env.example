# Lead Generation Browsing Service - Environment Configuration
# Copy this file to .env and fill in your actual values
# REQUIRED: DATABASE_URL must be set - no default provided

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/leadgen_db

# =============================================================================
# BROWSING SETTINGS
# =============================================================================
# Poll interval in seconds (how often to check for companies to browse)
BROWSING_POLL_INTERVAL=10

# HTTP request timeout (seconds)
BROWSING_TIMEOUT_HTTP=10

# Playwright browser timeout (seconds)
BROWSING_TIMEOUT_PLAYWRIGHT=30

# Per-domain timeout (seconds)
BROWSING_TIMEOUT_DOMAIN=45

# Max concurrent HTTP requests
BROWSING_CONCURRENCY_HTTP=20

# Max concurrent Playwright browsers
BROWSING_CONCURRENCY_PLAYWRIGHT=5

# Watchdog timeout (minutes) — resets stuck companies after this
BROWSING_WATCHDOG_MINUTES=15

# Maximum retry attempts per company
BROWSING_MAX_RETRIES=3

# =============================================================================
# SIGNAL SCORING
# =============================================================================
SCORE_MAX=10
SCORE_THRESHOLD_WEAK=2
SCORE_THRESHOLD_GOOD=5
SCORE_THRESHOLD_STRONG=8