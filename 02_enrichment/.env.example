# Database configuration
DATABASE_URL=postgresql://user:password@localhost:5432/leadgen

# Enrichment settings
ENRICHER_POLL_INTERVAL=60
HARVESTER_API_URL=http://localhost:5000
HARVESTER_SOURCES=duckduckgo
HARVESTER_LIMIT=500
OUTPUT_DIR=/tmp/leadgen_harvester

# Enrichment reliability config
ENRICHMENT_TIMEOUT_DOMAIN=60
ENRICHMENT_MAX_RETRIES=3
ENRICHMENT_WATCHDOG_MINUTES=15
TARGET_EMAILS_PER_DOMAIN=10