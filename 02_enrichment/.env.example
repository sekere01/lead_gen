# Lead Generation Enrichment Service - Environment Configuration
# Copy this file to .env and fill in your actual values
# REQUIRED: DATABASE_URL must be set - no default provided

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/leadgen_db

# =============================================================================
# ENRICHMENT SETTINGS
# =============================================================================
# Poll interval in seconds (how often to check for companies to enrich)
ENRICHER_POLL_INTERVAL=60

# theHarvester data sources (comma-separated)
HARVESTER_SOURCES=duckduckgo,bing

# Max results from harvester
HARVESTER_LIMIT=500

# Docker volume mount path for harvester output
OUTPUT_DIR=/tmp/leadgen_harvester

# Per-domain enrichment timeout (seconds)
ENRICHMENT_TIMEOUT_DOMAIN=60

# Maximum retry attempts per company
ENRICHMENT_MAX_RETRIES=3

# Watchdog timeout (minutes) — resets stuck companies after this
ENRICHMENT_WATCHDOG_MINUTES=15

# Target number of emails to collect per domain
TARGET_EMAILS_PER_DOMAIN=10