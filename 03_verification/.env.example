# Lead Generation Verification Service - Environment Configuration
# Copy this file to .env and fill in your actual values
# REQUIRED: DATABASE_URL must be set - no default provided

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/leadgen_db

# =============================================================================
# DATABASE CONNECTION POOL
# =============================================================================
# Increase pool_size if seeing "QueuePool limit reached" errors
# Verification runs concurrent email checks:
#   - pool_size: 10 (main loop + workers, with headroom)
#   - max_overflow: 5 (burst to 15 total)
#   - pool_timeout: 10 (seconds)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=10

# =============================================================================
# VERIFICATION SETTINGS
# =============================================================================
# Poll interval in seconds (how often to check for contacts to verify)
VERIFIER_POLL_INTERVAL=30

# SMTP verification timeout (seconds)
SMTP_TIMEOUT=5