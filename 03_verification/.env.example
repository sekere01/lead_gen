# Lead Generation Verification Service - Environment Configuration
# Copy this file to .env and fill in your actual values
# REQUIRED: DATABASE_URL must be set - no default provided

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/leadgen_db

# =============================================================================
# VERIFICATION SETTINGS
# =============================================================================
# Poll interval in seconds (how often to check for contacts to verify)
VERIFIER_POLL_INTERVAL=30

# SMTP verification timeout (seconds)
SMTP_TIMEOUT=5