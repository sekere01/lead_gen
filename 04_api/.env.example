# Lead Generation API Service - Environment Configuration
# Copy this file to .env and fill in your actual values
# REQUIRED: DATABASE_URL must be set - no default provided

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/leadgen_db

# Redis URL for Celery job queue
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API SERVER SETTINGS
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# CORS — comma-separated list of allowed origins
# Use http://localhost:3000 for local dev
# In production, set to your actual frontend domain(s)
ALLOWED_ORIGINS=http://localhost:3000